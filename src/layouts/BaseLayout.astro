---
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import type { Locale } from "@/types/content";
import { counterpartPath } from "@/lib/i18n";
import "@/styles/global.css";

interface Props {
  title: string;
  description: string;
  locale: Locale;
  image?: string;
  noindex?: boolean;
  showLanguageSwitch?: boolean;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const { title, description, locale, image = "/og-card.png", noindex = false, showLanguageSwitch = true, jsonLd } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const alternates = counterpartPath(Astro.url.pathname);
const fullTitle = title === "Weiping Yan" ? title : `${title} — Weiping Yan`;
---
<!doctype html>
<html lang={locale === "zh" ? "zh-Hans" : "en"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f3efe5" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />
    {!noindex && <link rel="alternate" hreflang="en" href={new URL(alternates.en, Astro.site)} />}
    {!noindex && <link rel="alternate" hreflang="zh-Hans" href={new URL(alternates.zh, Astro.site)} />}
    {!noindex && <link rel="alternate" hreflang="x-default" href={new URL(alternates.en, Astro.site)} />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${fullTitle} — ${description}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />
    <title>{fullTitle}</title>
    {jsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body>
    <a class="skip-link" href="#main-content">{locale === "en" ? "Skip to content" : "跳到正文"}</a>
    <div class="page-shell">
      <SiteHeader locale={locale} showLanguageSwitch={showLanguageSwitch} />
      <main id="main-content"><slot /></main>
      <SiteFooter locale={locale} />
    </div>
  </body>
</html>
